{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-social-network.dev/schemas/action-inbox.schema.json",
  "title": "Open Social Network Public Action Inbox",
  "type": "object",
  "additionalProperties": true,
  "required": ["protocol", "version", "owner", "actions"],
  "properties": {
    "protocol": {
      "const": "open-social-network"
    },
    "version": {
      "const": "0.1"
    },
    "owner": {
      "type": "string",
      "minLength": 3
    },
    "actions": {
      "type": "array",
      "items": {
        "$ref": "./action.schema.json"
      }
    }
  }
}
