{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-social-network.dev/schemas/post.schema.json",
  "title": "Open Social Network Post",
  "type": "object",
  "additionalProperties": true,
  "required": ["id", "author", "createdAt", "content", "signature"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "author": {
      "type": "string",
      "minLength": 3
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "content": {
      "type": "string",
      "minLength": 1
    },
    "replyTo": {
      "type": "string"
    },
    "links": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "media": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "url"],
        "properties": {
          "type": {
            "enum": ["image", "video", "audio"]
          },
          "url": {
            "type": "string"
          },
          "alt": {
            "type": "string"
          }
        }
      }
    },
    "signature": {
      "type": "object",
      "required": ["alg", "value"],
      "properties": {
        "alg": {
          "const": "ES256"
        },
        "value": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
