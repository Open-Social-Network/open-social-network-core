{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-social-network.dev/schemas/feed.schema.json",
  "title": "Open Social Network Feed",
  "type": "object",
  "additionalProperties": true,
  "required": ["protocol", "version", "author", "posts"],
  "properties": {
    "protocol": {
      "const": "open-social-network"
    },
    "version": {
      "const": "0.1"
    },
    "author": {
      "type": "string",
      "minLength": 3
    },
    "posts": {
      "type": "array",
      "items": {
        "$ref": "./post.schema.json"
      }
    }
  }
}
